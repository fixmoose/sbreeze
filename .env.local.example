# ──────────────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values.
# In Vercel, add these same keys under Project → Settings → Environment Variables.
# NEVER commit .env.local — it is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (photos + application records) ────────────────────────────────
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://mxxabikquupnwvlspzyz.supabase.co
# anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# service_role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_. Never expose.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── UniOne (transactional email notifications) ─────────────────────────────
# From UniOne dashboard → Settings → API keys
UNIONE_API_KEY=YOUR-UNIONE-API-KEY
# Use the endpoint for your account's region:
#   EU:  https://eu1.unione.io/en/transactional/api/v1
#   US:  https://us1.unione.io/en/transactional/api/v1
UNIONE_API_URL=https://eu1.unione.io/en/transactional/api/v1
# Must be a verified sender/domain in UniOne
UNIONE_FROM_EMAIL=no-reply@yourdomain.com
UNIONE_FROM_NAME=Sunset Breeze Rental

# ── Where new-application notifications are sent ───────────────────────────
APPLICATION_NOTIFY_EMAIL=dejan@haywilson.com

# ── Portal admin (landlord) ────────────────────────────────────────────────
# Comma-separated emails that get the LANDLORD dashboard. Everyone else who
# signs up is a tenant. Sign up with this email to become the admin.
ADMIN_EMAILS=dejan@haywilson.com

# ── PayPal (recurring rent subscriptions) ──────────────────────────────────
# From developer.paypal.com → Apps & Credentials. Use "sandbox" to test first.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=YOUR-PAYPAL-CLIENT-ID
PAYPAL_SECRET=YOUR-PAYPAL-SECRET
# Create a monthly billing plan (e.g. $2,450/mo) in PayPal and paste its plan id:
PAYPAL_PLAN_ID=P-XXXXXXXXXXXX
# After creating a webhook (URL: https://YOUR-DOMAIN/api/paypal/webhook), paste its id:
PAYPAL_WEBHOOK_ID=YOUR-WEBHOOK-ID

# ── Utility (NV Energy) auto-import ────────────────────────────────────────
# Shared secret so an automated importer (e.g. an email-forwarding parser) can
# POST a bill to /api/utilities with header  x-import-token: <this value>.
# Leave blank if you'll only enter bills manually in the dashboard.
UTILITY_IMPORT_TOKEN=

# ── Public site URL (used for SEO/metadata) ────────────────────────────────
# Optional; defaults to https://sunsetbreeze-phi.vercel.app
NEXT_PUBLIC_SITE_URL=https://sunsetbreeze-phi.vercel.app
